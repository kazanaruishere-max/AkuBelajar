# ============================================
# AkuBelajar — Environment Variables
# ============================================
# Copy ke .env dan isi nilainya:
# cp .env.example .env

# ---- App ----
PORT=8080
APP_ENV=development
FRONTEND_URL=http://localhost:3000

# ---- Database (PostgreSQL 16) ----
# Untuk production, gunakan DATABASE_URL:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=akubelajar
DB_PASSWORD=localdev123
DB_NAME=akubelajar_dev
DB_SSL_MODE=disable
DB_MAX_CONNS=25
DB_MAX_IDLE_TIME_MIN=15

# ---- Redis ----
# Untuk production (Upstash), gunakan REDIS_URL:
# REDIS_URL=rediss://default:[password]@[region].upstash.io:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Paseto v4 (Auth) ----
# Generate: openssl rand -hex 32
PASETO_KEY=
ACCESS_TOKEN_EXPIRY_MIN=15
REFRESH_TOKEN_EXPIRY_DAY=7

# ---- Gemini AI (opsional untuk dev) ----
# Dapatkan di: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Resend (Email) ----
# Dapatkan di: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@akubelajar.id

# ---- Supabase Storage ----
# Dapatkan di: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=uploads

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000
